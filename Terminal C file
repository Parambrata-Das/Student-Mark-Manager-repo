#include <stdio.h>
#include <stdlib.h>
#include <string.h>
struct student 
{
    int roll;
	char Name[100];
	float marks[100];
	float total;
	int total_marks;
	char grade[100];
	char remarks[100];
};
int enty_data(struct student s[], int *n,int *m)
{
	int i,j,new_students,total_marks;
	if(*n>0)
	{
		printf("Enter the number of new students: ");
		scanf("%d",&new_students);
	}
	else
	{
		printf("Enter the number of student: ");
	    scanf("%d",&new_students);
	}
	if(*m==0)
	{
	    printf("Enter the number of subjects: ");
	    scanf("%d", m);
    }
    printf("\n------Enter student record------\n");
    int limit=*n+new_students;
	for(i=*n;i<limit;i++)
	{
		s[i].total=0;
		s[i].total_marks=(*m)*100;
		printf("\nStudent name: ");
		scanf(" %[^\n]",s[i].Name);
		printf("Student Roll no.: ");
		scanf("%d",&s[i].roll);
		for(j=0;j<*m;j++)
		{
	    	printf("Subject %d marks: ",j+1);
		    scanf("%f",&s[i].marks[j]);
	    	s[i].total+=s[i].marks[j];
		}
		float diff = s[i].total_marks - s[i].total;
		if(diff<=10)
    	{
	    	strcpy(s[i].grade,"AA+");
	    	strcpy(s[i].remarks,"PASS");
	    }
	    else if(diff<=20 && diff>10)
 	    {
	    	strcpy(s[i].grade,"AA");
	    	strcpy(s[i].remarks,"PASS");
	    }
	    else if(diff<=50 && diff>20)
    	{
	    	strcpy(s[i].grade,"A+");
	    	strcpy(s[i].remarks,"PASS");
    	}
	    else if(diff<=100 && diff>50)
	    {
	    	strcpy(s[i].grade,"A");
	    	strcpy(s[i].remarks,"PASS");
		}
		 else if(diff<=150 && diff>100)
	    {
	    	strcpy(s[i].grade,"B+");
	        strcpy(s[i].remarks,"PASS");
		} 
		else if(diff<=200 && diff>150)
	    {
	    	strcpy(s[i].grade,"B");
	    	strcpy(s[i].remarks,"PASS");
		} 
		else if(diff<=250 && diff>200)
	    {
	    	strcpy(s[i].grade,"C");
	    	strcpy(s[i].remarks,"PASS");
		} 
		else if(diff<=300 && diff>250)
	    {
	    	strcpy(s[i].grade,"C+");
	    	strcpy(s[i].remarks,"PASS");
		} 
		else if(diff<=350 && diff>300)
	    {
	    	strcpy(s[i].grade,"F");
	    	strcpy(s[i].remarks,"FAIL");
		}
		else if(diff>350)
	    {
	    	strcpy(s[i].grade,"F+");
	    	strcpy(s[i].remarks,"FAIL");
		}
	}
	*n=limit;
	printf("\n======Data Entered Succeesfully======\n");
	return 0;
}
int display_data(struct student s[], int n)
{
	int i;
	printf("\n------Student Report Card------\n");
	if(n==0)
	{
		printf("Database is empty!!!\n");
	}
	else
	{
    	printf("%-10s %-25s %-10s %-10s %-10s %-10s\n", "Roll", "Name", "Total(G)", "Total(F)", "Grade", "Remarks");
        for(i = 0; i < n; i++)
        {
            printf("%-10d %-25s %-10.2f %-10d %-10s %-10s\n", s[i].roll, s[i].Name, s[i].total, s[i].total_marks, s[i].grade, s[i].remarks);
        }
    }
	return 0;
}
int search_student(struct student s[], int n)
{
	if(n==0)
	{
		printf("\nDatabase is empty!!!\n");
		return 0;
	}
	int i,choice,found=0;
	int search_roll;
	char search_name[100];
	printf("\n------Student Search------\n");
	printf("1. Search by roll number\n");
	printf("2. Search by student name\n");
	printf("\nEnter the choice: ");
	scanf("%d",&choice);
	if(choice==1)
	{
		printf("Enter the roll number: ");
		scanf("%d",&search_roll);
		for(i=0;i<n;i++)
		{
	    	if(s[i].roll==search_roll)
	    	{
			    if(found==0)
		    	{
		    		printf("\n%-10s %-25s %-10s %-10s %-10s %-10s\n", "Roll", "Name", "Total(G)", "Total(F)", "Grade", "Remarks");
	            }
	            printf("%-10d %-25s %-10.2f %-10d %-10s %-10s\n", s[i].roll, s[i].Name, s[i].total, s[i].total_marks, s[i].grade, s[i].remarks);
	            found++;
		    }
	    }
    }
	else if(choice==2)
	{
		printf("Enter the name: ");
		scanf(" %[^\n]",search_name);
		for(i=0;i<n;i++)
		{
		    if(strcmp(s[i].Name, search_name)==0)
	    	{
		    	if(found==0)
		    	{
		    		printf("\n%-10s %-25s %-10s %-10s %-10s %-10s\n", "Roll", "Name", "Total(G)", "Total(F)", "Grade", "Remarks");
		    	}
		    	printf("%-10d %-25s %-10.2f %-10d %-10s %-10s\n", s[i].roll, s[i].Name, s[i].total, s[i].total_marks, s[i].grade, s[i].remarks);
		    	found++;
	        }
    	}
    }
	else
	{
		printf("\nInvalid choice!!!!\n");
	}
	if(found==0)
	{
		printf("\nNo data found!!!\n");
	}
}
int delete_data(struct student s[], int *n)
{
	if(n==0)
	{
		printf("Database is empty!!!");
		return 0;
	}
	int i,j,search_roll,found=0;
	printf("\n------Delete student record------\n ");
	printf("Enter the roll number: ");
	scanf("%d",&search_roll);
	for(i=0;i<*n;i++)
	{
		if(s[i].roll==search_roll)
		{
			found=1;
			for(j=i;j<*n-1;j++)
			{
				s[j]=s[j+1];
			}
			(*n)--;
			i--;
		}
	}
	 if(found)
    {
        printf("\n======Record Deleted Successfully======\n");
    }
    else
    {
        printf("\nStudent with Roll No %d not found!\n", search_roll);
    }
    return 0;
	
}
int main()
{
	struct student s[100];
	int student_count=0;
	int subject_count=0;
	int ch;
    do {
        printf("\n1.Insert \n2.Display \n3.Search \n4.Delete \n5.Exit \n");
        printf("Enter your choice: ");
        scanf("%d",&ch);
        switch(ch) {
        case 1:
        	if(student_count>=100)
        	{
        		printf("Database full can't store more elements");
			}
			else
			{
                enty_data(s,&student_count,&subject_count);
            }
			break;
        case 2:
            display_data(s,student_count);
            break;
        case 3:
		    search_student(s,student_count); 
			break;
		case 4:
		    delete_data(s,&student_count);
		    break;
        case 5:
            exit(0);
            break;
        default:
            printf("Invalid choice");
        }
    } while(1);
}
